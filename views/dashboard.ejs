<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Dashboard</title>
    <link rel="stylesheet" href="/styles/styles.css" />
    <link rel="stylesheet" href="/styles/dashboard.css" />
    <link rel="stylesheet" href="/styles/header.css" />
    <link rel="stylesheet" href="/styles/footer.css" />
    <link rel="stylesheet" href="/styles/viewWindow.css" />
    <link rel="stylesheet" href="/styles/sidebar.css" />
    <script src="/js/modal.js" defer></script>
  </head>
  <body>
    <% if (user) { %>
      <section class="dashboard-container">
      <!-- Header -->
      <%- include('header') %>

      <!-- Body Row: Sidebar + Content -->
      <div class="dashboard-body">
        <%- include('sidebar') %>

        <!-- Content -->
        <main><%- include('viewWindow') %></main>
      </div>

      <!-- Footer -->
      <%- include('footer') %>
    </section>
    <% } else { %>
      <section class="error-page">
        <h1>404 error</h1>
        <br>
        <a href="/login">
          <button>Back to Log In</button>
        </a>
      </section>
    <% } %>

    <!-- Modal Boxes -->
    <!-- Folder Modal -->
    <div class="modal-container">
      <div class="modal" id="folderModal">
        <form action="<%= currentFolderId ? `/folders/${currentFolderId}/new` : '/folders/new' %>" method="POST">
          <div class="title-x-group">
            <h2>New folder</h2>
            <button type="button" class="close-btn">X</button>
          </div>
          <input type="text" name="folder" placeholder="Folder name">
          <button type="submit">Create</button>
        </form>
      </div>
    </div>

    <!-- Rename Folder Modal -->
    <div class="modal-container">
      <div class="modal" id="renameFolderModal">
        <form action="" method="POST" id="renameFolderForm">
          <div class="title-x-group">
            <h2>Rename folder</h2>
            <button type="button" class="close-btn">X</button>
          </div>
          <input type="text" name="foldername" placeholder="New folder name">
          <button type="submit">Rename</button>
        </form>
      </div>
    </div>

    <!-- File Modal -->
    <div class="modal-container">
      <div class="modal" id="fileModal">
        <form action="<%= currentFolderId ? `/files/upload/${currentFolderId}` : '/files/upload' %>" method="POST" enctype="multipart/form-data">
          <div class="title-x-group">
            <h2>New file</h2>
            <button type="button" class="close-btn">X</button>
          </div>
          <input type="file" name="file" placeholder="File">
          <button type="submit" class="newFileBtn">Upload</button>
        </form>
      </div>
    </div>
    
    <!-- Pass messages -->
    <script>
      const successMessages = <%- JSON.stringify(success ?? []) %>;
      const errorMessages = <%- JSON.stringify(error ?? []) %>;

      const successArray = Array.isArray(successMessages)
        ? successMessages
        : successMessages
        ? [successMessages]
        : [];

      const errorArray = Array.isArray(errorMessages)
        ? errorMessages
        : errorMessages
        ? [errorMessages]
        : [];
    </script>

    <!-- Load toast.js FIRST -->
    <script src="/js/toast.js"></script>

    <!-- THEN call it -->
    <script>
      successArray.forEach(msg => showToast(msg, "success"));
      errorArray.forEach(msg => showToast(msg, "error"));
    </script>
  </body>
</html>
