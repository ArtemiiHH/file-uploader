<section class="view-window">
  <% if (files.length === 0 && folders.length === 0) { %>
    <h3>Nothing added yet. Click "new" to add files or folders.</h3>
  <% } else { %>

    <!-- Folders -->
    <% folders.forEach(folder => { %>
      <div class="folder-card" data-id="<%= folder.id %>">
        <button class="dot-menu">⋮</button>
        <div class="dropdown">
          <button class="rename-btn" data-id="<%= folder.id %>">Rename</button>
          <form action="/folders/<%= folder.id %>?_method=DELETE" method="POST">
            <button type="submit">Delete</button>
          </form>
        </div>
        <div class="card-details">
          <p class="file-icon">📁</p>
          <p class="file-name"><%= folder.foldername %></p>
        </div>
      </div>
    <% }) %>

    <!-- Files -->
    <% files.forEach(file => { %>
      <div class="file-card" data-id="<%= file.id %>">
        <button class="dot-menu">⋮</button>
        <div class="dropdown">
          <a href="<%= file.url %>" target="_blank"><button>Download</button></a>
          <form action="/files/<%= file.id %>?_method=DELETE" method="POST">
            <button type="submit">Delete</button>
          </form>
        </div>
        <div class="card-details">
          <p class="file-icon">📄</p>
          <p class="file-name"><%= file.filename %></p>
        </div>
      </div>
    <% }) %>
  <% } %>
</section>